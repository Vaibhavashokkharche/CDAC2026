package com.demo.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.validation.BindingResult;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.servlet.ModelAndView;

import com.demo.beans.Product;
import com.demo.service.ProductService;

import jakarta.validation.Valid;

@RequestMapping("/product")
@Controller
public class ProductController {
	@Autowired
	private ProductService pservice;

	@GetMapping("/viewProducts")
	public ModelAndView getAllproduct() {

		List<Product> plist = pservice.getAllProduct();
		System.out.println(plist);
		if (plist != null) {

			return new ModelAndView("displayall", "plist", plist);
		}

		return new ModelAndView("Login");

	}

	@GetMapping("/addproduct")
	public String addnewproduct(Model model) {

		model.addAttribute("product", new Product());
		System.out.println("in modelattribute after");

		return "addproduct";
	}

	@PostMapping("/save")
	public String insertNewProduct(@Valid @ModelAttribute("product") Product product, BindingResult result ) {
		System.out.println("in insert new product");

		System.out.println(product);
		boolean status = pservice.insertNewProduct(product);

		return "redirect:/product/viewProducts";
	}

	@GetMapping("editproduct/{pid}")
	public String updateProduct(@PathVariable("pid") int pid, Model model) {
		Product p = pservice.getProductById(pid);
		model.addAttribute("product", p);

		return "editproduct";
	}

	@PostMapping("editproduct/update")
	public String updateProduct(@Valid @ModelAttribute("product") Product product) {

		boolean status = pservice.updateProductById(product);
		if (status) {

			return "redirect:/product/viewProducts";
		}

		return "editproduct";
	}

	@GetMapping("/deleteproduct/{pid}")
	public String deleteProduct(@PathVariable("pid") int pid) {

		boolean status = pservice.deleteById(pid);

		return "redirect:/product/viewProducts";
	}

}
