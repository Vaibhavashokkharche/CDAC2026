	}

	@Override
	public List<Vehicle> findAll() {
		List<Vehicle> vlist = new ArrayList<>();
		for (Integer k : vmap.keySet()) {
			vlist.add(vmap.get(k));

		}

		return vlist;
	}

	@Override
	public boolean save(Vehicle v) {
		vmap.put(v.getVid(), v);
		return true;
	}

	@Override
	public boolean removeById(int id) {
		Scanner sc = new Scanner(System.in);
		for (Integer k : vmap.keySet()) {
			Vehicle v = vmap.get(k);
			if (v.getVid() == id) {
				System.out.println("Do you want delete it y/n");
				String cmsg = sc.next();
				if (cmsg.equals("y")) {
					vmap.remove(k);
					return true;

				}

			}

		}

		return false;
	}

	@Override
	public boolean modifyById(int id, double nprice) {
		for (Integer k : vmap.keySet()) {
			Vehicle v = vmap.get(k);

			if (v.getVid() == id) {
				v.setPrice(nprice);
				return true;
			}

		}

		return false;
	}

	@Override
	public Vehicle findById(int id) {
		for (Integer k : vmap.keySet()) {
			Vehicle v = vmap.get(k);
			if (v.getVid() == id) {
				return v;
			}
		}
		return null;
	}

	@Override
	public List<Vehicle> getByPrice(double price) {
		List<Vehicle> vlist = new ArrayList<>();
		for (Integer k : vmap.keySet()) {
			Vehicle v = vmap.get(k);
			if (v.getPrice() == price) {
				vlist.add(v);
			} 
		}
		return vlist;
	}

	@Override
	public List<Vehicle> findByName(String nm) {
		List<Vehicle> vlist=new ArrayList<>();
		for(Integer k:vmap.keySet()) {
			Vehicle v= vmap.get(k);
			if(v.getVname().equals(nm)) {
			vlist.add(v);
			}
			
			
		}
		return vlist;
	}

