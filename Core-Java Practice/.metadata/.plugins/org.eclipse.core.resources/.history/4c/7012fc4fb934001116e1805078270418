public class VehicleDaoImpl implements VehicleDao {
	static Map<Integer, Vehicle> vmap;

	static {
		vmap = new HashMap<>();
		vmap.put(11, new Vehicle(11, "MarutiSuzuki", "Breeza", 1100000, LocalDate.of(2017, 11, 26)));
