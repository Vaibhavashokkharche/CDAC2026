package com.day2;

public class Addition {
	Addition() {

		System.out.println("Default Constructor called");
	}

	public int add(int a, int b) {
		return (a + b);
	}

	public int add(int a, int b, int c) {
		return (a + b + c);
	}

	public float add(float a, int b) {

		return (a + b);
	}

	public double add(double a, double b) {

		return (a + b);
	}

};
//method of overloading
	// Every class consists of constructor/destructor/getter/setter 
	//and Normal function
    // same method name but they differ number of arguments and thier types is called as method of overloading
	// it also known as complile time polymorphism