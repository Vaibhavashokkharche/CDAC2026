package com.day3;

import java.util.Scanner;

public class Array2DService {
	//accepct the data from user
	public static void accpectData(int arr[][]) {
		Scanner sc = new Scanner(System.in);
		for (int i = 0; i < arr.length; i++) {
			for (int j = 0; j < arr[i].length; j++) {
				System.out.println("Enter the " + i + "row and" + j + "column value");
				arr[i][j] = sc.nextInt();

			}
			System.out.println();
		}
		System.out.println("Data Added Sucessfully");

	}

	// display the Data from 2DArray
	public static void displayData(int arr[][]) {
		System.out.println("2D Array");
		for (int i = 0; i < arr.length; i++) {
			for (int j = 0; j < arr[i].length; j++) {
				System.out.print(arr[i][j] + " ");
			}

			System.out.println();
		}

	}
//find the maximum number from entire array
	public static int findMax(int arr[][]) {
		int max = arr[0][0];
		for (int i = 0; i < arr.length; i++) {
			for (int j = 0; j < arr[i].length; i++) {

				if (arr[i][j] > max) {
					max = arr[i][j];

				}

			}

		}
		return max;
	}
	
	
	
	
	
