package com.day2;

import java.util.Locale;

public class StringMethods {
public static void main(String[] args) {
	
	String s1 ="ay name is Vaibhav Kharche";
	//to covert the string into lowercase
	System.out.println(s1.toLowerCase());
	//to convert the String in UpperCase
	System.out.println(s1.toUpperCase());
	//to checking string lexographically
	System.out.println(s1.compareTo("rushikesh"));
	//retrving the char as per index
	for(int i =0 ;i<s1.length();i++) {
	System.out.println(s1.charAt(i));
	}
	//to remove the extraspaces before and after string
	System.out.println(s1.trim());
	//It retun the assci value of char before/after/at  that index;
	System.out.println(s1.codePointBefore(1));
	System.out.println(s1.codePointAt(1));
	System.out.println(s1.codePointCount(0, 4));
	
}
}
