class Calculator{
public static void main(String[]args){
// user give the input from cmd line args one operand and two number 
// we calculate the given number as per operand
int ans =0;
if(args.length<3){
System.out.println("Give at least 3 para like(+ 2 5)");
}else
switch(args[0]){
 case "+":
 ans= Integer.parseInt(args[1])+Integer.parseInt(args[2]);
 System.out.println("Addition : "+ans);
 break;
 
 case "-":
 ans= Integer.parseInt(args[1])-Integer.parseInt(args[2]);
 System.out.println("Substraction: "+ans);
 break;
 
 case "x":
 ans= Integer.parseInt(args[1])*Integer.parseInt(args[2]);
 System.out.println("Multiplication :"+ans);
 break;
 
case "/":
 ans= Integer.parseInt(args[1])/Integer.parseInt(args[2]);
 System.out.println("Divison: "+ans);
 break;
 
}

}

};