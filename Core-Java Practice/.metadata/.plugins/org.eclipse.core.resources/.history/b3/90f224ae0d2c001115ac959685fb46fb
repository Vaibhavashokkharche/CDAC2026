package com.day3;

import java.util.Scanner;

public class ArrayService {
	private static int getDigitAddition(int num) {
		int sum = 0;
		while (num != 0) {
			int rem = num % 10;
			sum += rem;
			num = num / 10;
		}
		return sum;
	}

	// accept data in the array
	public static void accpectdata(int arr[]) {
		Scanner sc = new Scanner(System.in);
		for (int i = 0; i < arr.length; i++) {
			System.out.println("Enter the" + i + "element");
			arr[i] = sc.nextInt();
		}
	}

	// display the data of array
	public static void displayData(int arr[]) {
		for (int i = 0; i < arr.length; i++) {

			System.out.print(arr[i] + " ");
		}
	}

	// search whether num exists int he array and return position
	public static int searchData(int arr[], int num) {
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] == num) {
				return i;
			}
		}
		return -1;
	}

	// find sum of all numbers
	public static int findSum(int arr[]) {
		int sum = 0;
		for (int i = 0; i < arr.length; i++) {

			sum += arr[i];
		}
		return sum;
	}

	// Find the max number in array
	public static int findMax(int arr[]) {
		int max = arr[0];
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] > max) {
				max = arr[i];
			}
		}
		return max;
	}

	// Find the max number in array
	public static int findMin(int arr[]) {
		int min = arr[0];
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] < min) {
				min = arr[i];
			}
		}
		return min;
	}
	// find addition of digits of a number

	public static int[] findDigitAdd(int arr[]) {
		int arr1[] = new int[arr.length];
		for (int i = 0; i < arr.length; i++) {
			arr1[i] = getDigitAddition(arr[i]);
		}
		return arr1;
	}

};
